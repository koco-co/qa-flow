# ══════════════════════════════════════════════════════════════════════════════
# qa-flow 多环境配置模板
# 复制为 .env.envs 并填入实际值。.env.envs 已加入 .gitignore
#
# 加载顺序（高 → 低）：.env.local > .env.envs > .env > process.env
#
# 命名规则：{ENV}_BASE_URL、{ENV}_COOKIE、{ENV}_USERNAME、{ENV}_PASSWORD、{ENV}_DOMAIN
# 多实例并行：ACTIVE_ENV=ci63 bunx playwright test ...
# ══════════════════════════════════════════════════════════════════════════════

# 当前活跃环境标识（切换环境只需改这一行）
ACTIVE_ENV=

# ──────────────────────────────────────────────
# 示例：自定义环境段模板
# 每新增一个环境，复制下段并把 {ENV} 替换为大写环境名
# ──────────────────────────────────────────────
# {ENV}_BASE_URL=http://xxx.k8s.dtstack.cn
# {ENV}_USERNAME=admin@dtstack.com
# {ENV}_PASSWORD=
# {ENV}_DOMAIN=xxx.k8s.dtstack.cn
# {ENV}_COOKIE=
